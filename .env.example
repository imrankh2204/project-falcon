##################################################
# Application
##################################################

APP_NAME=ProjectFalcon
APP_VERSION=0.1.0-alpha
APP_ENV=paper
TIMEZONE=Asia/Kolkata

##################################################
# Broker
##################################################

BROKER=zerodha

KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

##################################################
# Database
##################################################

DATABASE_URL=sqlite:///data/falcon.db

##################################################
# Logging
##################################################

LOG_LEVEL=INFO
LOG_DIRECTORY=logs

##################################################
# Trading
##################################################

PAPER_TRADING=true

MAX_TRADES_PER_DAY=3

MAX_DAILY_LOSS=3000

MAX_OPEN_POSITIONS=1

##################################################
# Telegram
##################################################

TELEGRAM_ENABLED=false

TELEGRAM_BOT_TOKEN=

TELEGRAM_CHAT_ID=

##################################################
# Dashboard
##################################################

DASHBOARD_PORT=8501

##################################################
# Debug
##################################################

DEBUG=false